{
  "rewrites": [
    {
      "source": "/callback",
      "destination": "/api/callback"
    },
    {
      "source": "/webhook/facebook",
      "destination": "/api/webhook/facebook"
    },
    {
      "source": "/terms",
      "destination": "/terms/index.html"
    },
    {
      "source": "/privacy",
      "destination": "/privacy/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
